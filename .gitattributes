# Enforce LF line endings on checkout/commit
* text=auto eol=lf

# Exclude dev-only paths from the Composer dist tarball (git archive / GitHub zipball).
# Without this, docs/ (internal infra planning), tests/, CI config and dev tooling
# all ship into vendor/ on every client site that installs this package.
/.github               export-ignore
/build                 export-ignore
/docs                  export-ignore
/scripts               export-ignore
/tests                 export-ignore
/.editorconfig         export-ignore
/.env.example          export-ignore
/.env.testing.example  export-ignore
/.gitattributes        export-ignore
/.gitignore            export-ignore
/CONTRIBUTING.md       export-ignore
/TODO.md               export-ignore
/VERSION_MANAGEMENT.md export-ignore
/phpstan.neon          export-ignore
/phpunit.xml           export-ignore
/pint.json             export-ignore
/rector.php            export-ignore
